// scripts/generateDailyArticle.js

const fs = require("fs");
const path = require("path");

const OUTPUT_DIR = path.join(__dirname, "../docs");

function buildPage(route, origin, dest) {
  const title = `${origin} to ${dest} deals`;
  const href = `https://convert.ctypy.com/aff_c?offer_id=29465&aff_id=21885&utm_source=skydeals&utm_medium=web&utm_campaign=${route}`;

  const html = `
<!DOCTYPE html>
<html>
<head><title>${title}</title></head>
<body>
  <h1>${title}</h1>
  <p>Search for cheap flights from <strong>${origin}</strong> to <strong>${dest}</strong>.</p>
  <a href="${href}" data-skydeal data-origin="${origin}" data-destination="${dest}" target="_blank" rel="noopener sponsored">
    View Skyscanner‑style deals
  </a>
</body>
</html>
`.trim();

  const file = path.join(OUTPUT_DIR, `${route}.html`);
  if (!fs.existsSync(OUTPUT_DIR)) {
    fs.mkdirSync(OUTPUT_DIR, { recursive: true });
  }
  fs.writeFileSync(file, html);
  console.log(`✓ ${file}`);
}

const ROUTES = [
  ["nyc-mia", "NYC", "MIA"],
  ["phl-mco", "PHL", "MCO"],
  ["phl-mia", "PHL", "MIA"],
  ["nyc-mco", "NYC", "MCO"],
];

if (require.main === module) {
  ROUTES.forEach(([route, origin, dest]) => buildPage(route, origin, dest));
  console.log("✅ done");
}
